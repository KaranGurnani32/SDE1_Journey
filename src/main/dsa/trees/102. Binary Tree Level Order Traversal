/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
/* I checked the soln and then applied it I was confused on how we are
considering all elements at same level, it is happening as when we add
root after that we add the left and right to queue then one level down
we add left and right elements of first element then next one and so on
it happend when inside for loop we do poll like it covers all the elements

*/
    List<List<Integer>> result = new ArrayList<>();
    public List<List<Integer>> levelOrder(TreeNode root) {
        if (root == null) return result;

        Queue<TreeNode> queue = new LinkedList<>();
        queue.add(root);

        while(!queue.isEmpty()) {
            int levelSize = queue.size();
            List<Integer> current = new ArrayList<>();

            for (int i = 0; i < levelSize; i++) {
                TreeNode element = queue.poll();
                current.add(element.val);

                if (element.left != null) {
                    queue.add(element.left);
                }
                if (element.right != null) {
                    queue.add(element.right);
                }
            }
            result.add(new ArrayList<>(current));
        }

        return result;
    }
}